   351                              <1> print_uint64_ascii:		;Formats unsigned 64 bit value in RAX as decimal ASCII string
   352 00000472 BF00000000          <1> 	mov rdi, 0		;ASCII digit counter
   353                              <1> .0:
   354 00000477 BA00000000          <1> 	mov rdx, 0		;pad top 64 bits of RDX:RAX dividend to 0
   355 0000047C BB0A000000          <1> 	mov rbx, 10		;Divide by 10
   356 00000481 48F7F3              <1> 	div rbx			;Remainder is our ascii character, result gets recycled
   357 00000484 8897[09000000]      <1> 	mov [outb+rdi],dl	;Save our unconverted value
   358 0000048A 48FFC7              <1> 	inc rdi
   359 0000048D 4883F800            <1> 	cmp rax, 0		;Are we at "0 remainder something" yet?
   360 00000491 7FE4                <1> 	jg .0			;If not, cycle again and get the next digit
   361                              <1> 
   362 00000493 48893D(59000000)    <1> 	mov [asciilen], rdi	;stash our string length
   363 0000049A 4889F9              <1> 	mov rcx, rdi		;Make it our counter
   364 0000049D 48FFCF              <1> 	dec rdi			;Position it over our last character
   365 000004A0 4889FE              <1> 	mov rsi, rdi		;Make it our source offset
   366 000004A3 4881C6[09000000]    <1> 	add rsi, outb		;Make our offset an address pointer
   367 000004AA 48BF-               <1> 	mov rdi, ascii		;Set up output pointer
   367 000004AC [3100000000000000]  <1>
   368                              <1> .1:
   369 000004B4 FD                  <1> 	std			;Reverse our number string and make it printable
   370 000004B5 AC                  <1> 	lodsb			;Load first byte and decrement RSI
   371 000004B6 0C30                <1> 	or al, 30h		;Make it an ASCII character
   372 000004B8 FC                  <1> 	cld
   373 000004B9 AA                  <1> 	stosb			;Stash it in the ASCII buffer
   374 000004BA E2F8                <1> 	loop .1			;Recycle until finished
   375 000004BC C3                  <1> 	ret
   376                              <1> 
   377                              <1> print_uint64:			;Prints unsigned 64 bit value in RAX as decimal
