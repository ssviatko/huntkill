     3                                  	global maze_init
     4                                  	global maze_display
     5                                  	global maze_generate
     6                                  
     7                                  	DEFAULT REL
     8                                  
     9                                  	section .text
    10                                  
    11                                  ; Calling convention:
    12                                  ; RDI, RSI, RDX, RCX, R8, R9
    13                                  ; (then stack)
    14                                  
    15                                  ; Initialize the maze to a starting condition:
    16                                  ; All left/top walls in place, except for the outer edges.
    17                                  ; right edge has left wall in place, bottom row has top wall.
    18                                  
    19                                  maze_init:
    20 000006EA 53                      	push rbx
    21 000006EB 55                      	push rbp
    22 000006EC 4889E5                  	mov rbp, rsp
    23                                  
    24 000006EF 48893D(E0000000)        	mov [maze_height], rdi
    25 000006F6 488935(E8000000)        	mov [maze_width], rsi
    26 000006FD 488915(F0000000)        	mov [maze_ptr], rdx
    27                                  
    28                                  ; set all middle contents to default value
    29                                  
    30 00000704 4889F8                  	mov rax, rdi		;set up our width/height in rax and rbx for multiply operation
    31 00000707 4889F3                  	mov rbx, rsi
    32 0000070A 4889D7                  	mov rdi, rdx 		;get destination address of array into DI
    33 0000070D 48F7E3                  	mul rbx
    34 00000710 4889C1                  	mov rcx, rax		;height * width becomes number of bytes to set in array
    35 00000713 B060                    	mov al, 0b01100000	;visited = 0, top wall = 1, left wall = 1
    36 00000715 FC                      	cld
    37 00000716 F3AA                    	rep stosb		;clear entire array to default values
    38                                  
    39                                  ; lower row
    40                                  
    41 00000718 488B3D(F0000000)        	mov rdi, [maze_ptr]	;restore pointer we were passed
    42 0000071F 488B1D(E8000000)        	mov rbx, [maze_width]	;width into rbx
    43 00000726 488B05(E0000000)        	mov rax, [maze_height]	;height into rax
    44                                  
    45 0000072D 48FFC8                  	dec rax			;get the last row (height - 1)
    46 00000730 48F7EB                  	imul rbx		;make pointer to first item in last row: (height -1) * width
    47 00000733 4801C7                  	add rdi, rax		;add our existing data pointer
    48                                  
    49 00000736 4889D9                  	mov rcx, rbx		;set exactly WIDTH number of bytes - 1
    50 00000739 48FFC9                  	dec rcx
    51 0000073C B040                    	mov al, 0b01000000	;visited = 0, top wall = 1, left wall = 0
    52 0000073E FC                      	cld
    53 0000073F F3AA                    	rep stosb
    54                                  
    55                                  ; right side wall
    56                                  
    57 00000741 488B3D(F0000000)        	mov rdi, [maze_ptr]	;get our pointer back
    58 00000748 488B1D(E8000000)        	mov rbx, [maze_width]	;width into rbx
    59 0000074F 488B0D(E0000000)        	mov rcx, [maze_height]	;height into rcx
    60 00000756 48FFC9                  	dec rcx			;height -1
    61                                  .0:
    62                                  				;the following 2 instructions explained:
    63                                  				;first time through loop: point rdi to last element of first row
    64                                  				;subsequently, add 1 height next time(s) through loop
    65                                  				; (dec rdi takes care of extraneous DI increment by stosb instruction)
    66 00000759 4801DF                  	add rdi, rbx
    67 0000075C 48FFCF                  	dec rdi
    68                                  
    69 0000075F B020                    	mov al, 0b00100000	;visited = 0, top wall = 0, left wall = 1
    70 00000761 AA                      	stosb			;automatically increments DI; but this is taken care of by dec rdi above
    71 00000762 48FFC9                  	dec rcx			;   the next time it goes through the loop!
    72 00000765 75F2                    	jne .0
    73                                  
    74                                  ; lower right side corner
    75                                  
    76 00000767 488B3D(F0000000)        	mov rdi, [maze_ptr]	;pointer
    77 0000076E 488B1D(E8000000)        	mov rbx, [maze_width]	;width
    78 00000775 488B05(E0000000)        	mov rax, [maze_height]	;height
    79 0000077C 48FFC8                  	dec rax			;height-1 (point to last row)
    80 0000077F 48F7E3                  	mul rbx			;rax = width * (height-1)
    81 00000782 4801D8                  	add rax, rbx		;add height
    82 00000785 48FFC8                  	dec rax			;point it to last member
    83 00000788 4801C7                  	add rdi, rax		;apply it to the pointer
    84 0000078B B000                    	mov al, 0x0		;visited = 0, top wall = 0, left wall = 0
    85 0000078D 8807                    	mov [rdi], al
    86                                  
    87 0000078F 5D                      	pop rbp
    88 00000790 5B                      	pop rbx
    89                                  
    90 00000791 C3                      	ret
    91                                  
    92                                  ; helper functions
    93                                  
    94                                  ; maze_ptr2cell
    95                                  ; This routine takes cell hpos=r8 wpos=r9 and returns a pointer
    96                                  ; to the cell in rdx based on the value in maze_ptr.
    97                                  ; saves all registers
    98                                  
    99                                  maze_ptr2cell:
   100 00000792 4C89C0                  	mov rax, r8
   101 00000795 48F725(E8000000)        	mul qword [maze_width]
   102 0000079C 4C01C8                  	add rax, r9
   103 0000079F 480305(F0000000)        	add rax, [maze_ptr]
   104 000007A6 4889C2                  	mov rdx, rax
   105 000007A9 8A02                    	mov al, [rdx]
   106 000007AB C3                      	ret
   107                                  
   108                                  ; Pretty print the maze.
   109                                  ; hscale = number of character cells each maze cell should be tall,
   110                                  ; wscale = number of character cells each maze cell should be wide.
   111                                  ; maze_ptr is the pointer to the maze array.
   112                                  
   113                                  maze_display:
   114 000007AC 53                      	push rbx
   115 000007AD 55                      	push rbp
   116 000007AE 4889E5                  	mov rbp, rsp
   117                                  
   118 000007B1 48893D(E0000000)        	mov [maze_height], rdi			;save all our arguments
   119 000007B8 488935(E8000000)        	mov [maze_width], rsi
   120 000007BF 488915(F0000000)        	mov [maze_ptr], rdx
   121 000007C6 48890D(F8000000)        	mov [maze_height_scale], rcx
   122 000007CD 4C8905(00010000)        	mov [maze_width_scale], r8
   123                                  
   124 000007D4 4D31C0                  	xor r8, r8						;clear height loop counter
   125                                  .icycle:
   126 000007D7 4D31C9                  	xor r9, r9						;clear width loop counter for top wall
   127                                  .jcycle1:
   128                                  ; display top wall of cell r8, r9
   129 000007DA E8B3FFFFFF              	call maze_ptr2cell
   130 000007DF 2440                    	and al, 0b01000000
   131 000007E1 7404                    	jz .notop
   132 000007E3 B02D                    	mov al, '-'
   133 000007E5 EB02                    	jmp .printtop
   134                                  .notop:
   135 000007E7 B020                    	mov al, ' '
   136                                  .printtop:
   137 000007E9 488B0D(00010000)        	mov rcx, [maze_width_scale]
   138                                  .printtop1:
   139 000007F0 51                      	push rcx
   140 000007F1 50                      	push rax
   141 000007F2 4150                    	push r8
   142 000007F4 4151                    	push r9
   143 000007F6 E840F8FFFF              	call print_char
   144 000007FB 4159                    	pop r9
   145 000007FD 4158                    	pop r8
   146 000007FF 58                      	pop rax
   147 00000800 59                      	pop rcx
   148 00000801 E2ED                    	loop .printtop1
   149                                  .jrecycle1:
   150 00000803 49FFC1                  	inc r9
   151 00000806 4C3B0D(E8000000)        	cmp r9, [maze_width]
   152 0000080D 72CB                    	jb .jcycle1
   153                                  
   154 0000080F 4150                    	push r8
   155 00000811 4151                    	push r9
   156 00000813 E81BF8FFFF              	call print_cr
   157 00000818 4159                    	pop r9
   158 0000081A 4158                    	pop r8
   159                                  
   160                                  ; loop [maze_height_scale] number of times to render the left side walls
   161                                  
   162 0000081C 4D31D2                  	xor r10, r10
   163                                  .kcycle:
   164 0000081F 4D31C9                  	xor r9, r9
   165                                  .jcycle2:
   166                                  
   167                                  ; print "|   " or "    " depending on left wall flag in cell
   168 00000822 E86BFFFFFF              	call maze_ptr2cell
   169 00000827 50                      	push rax				;save, so we can check visited status
   170 00000828 2420                    	and al, 0b00100000
   171 0000082A 7404                    	jz .noside
   172 0000082C B07C                    	mov al, '|'
   173 0000082E EB02                    	jmp .printside
   174                                  .noside:
   175 00000830 B020                    	mov al, ' '
   176                                  .printside:
   177                                  
   178                                  ; print left-size character as set above
   179 00000832 4150                    	push r8
   180 00000834 4151                    	push r9
   181 00000836 4152                    	push r10
   182 00000838 E8FEF7FFFF              	call print_char
   183 0000083D 415A                    	pop r10
   184 0000083F 4159                    	pop r9
   185 00000841 4158                    	pop r8
   186                                  
   187                                  ; restore rax and check for visited status
   188 00000843 58                      	pop rax
   189 00000844 2480                    	and al, 0b10000000
   190 00000846 740B                    	jz .novis
